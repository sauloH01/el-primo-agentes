# Copia este archivo a .dev.vars y rellena con valores reales para desarrollo local.
# NUNCA subas .dev.vars al repositorio (ya está en .gitignore).
# En producción usa: npx wrangler secret put NOMBRE_VARIABLE

OPENAI_API_KEY=sk-...
WHATSAPP_ACCOUNT_SID=ACxxxxxx
WHATSAPP_AUTH_TOKEN=xxxxxxxx
ADMIN_API_TOKEN=token-seguro-largo
HUBSPOT_ACCESS_TOKEN=pat-na1-...
COTIZADOR_SECRET=secreto-compartido-cotizador

# Omite SKIP_TWILIO_VALIDATION en producción.
# En local puedes poner: SKIP_TWILIO_VALIDATION=1
