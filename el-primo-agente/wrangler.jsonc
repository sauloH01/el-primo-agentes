// wrangler.jsonc — Cloudflare Worker "el-primo-agente"
// Agente de WhatsApp (Twilio) + API admin para el dashboard.
//
// IMPORTANTE — los SECRETOS no van aquí. Se cargan con:
//   wrangler secret put OPENAI_API_KEY
//   wrangler secret put WHATSAPP_ACCOUNT_SID
//   wrangler secret put WHATSAPP_AUTH_TOKEN
//   wrangler secret put ADMIN_API_TOKEN
//   wrangler secret put HUBSPOT_ACCESS_TOKEN   (mismo token del elprimo-lead-worker)
{
  "name": "el-primo-agente",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,

  // Pega aquí tu Account ID de Cloudflare (Dashboard → Workers → Overview).
  "account_id": "0fb22483300c6f8b8d6e8644424b396e",

  // Variables NO secretas (visibles). Los secretos se cargan aparte.
  "vars": {
    // Número de WhatsApp del agente en Twilio, formato E.164 con whatsapp:
    // Sandbox de Twilio: "+14155238886"
    "WHATSAPP_SENDER_NUMBER": "+14155238886",
    // WhatsApp personal de Audenar (recibe el aviso de lead calificado), E.164.
    "AUDENAR_PHONE": "+573223306682",
    // Id de este agente dentro de la base D1 (debe existir en la tabla agents).
    "AGENT_ID": "el-primo-agente",
    // HubSpot (espejo de leads). Mismos valores que elprimo-lead-worker.
    "HUBSPOT_PIPELINE_ID": "default",
    "HUBSPOT_DEALSTAGE_ID": "1374171315"
  },

  // Base de datos D1 (fuente única de verdad del CRM).
  // Crea la base con:  wrangler d1 create elprimo-crm
  // y pega el database_id que te devuelve.
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "elprimo-crm",
      "database_id": "7b67cd56-11ec-4262-839c-9f6bd9e25aef"
    }
  ],

  "observability": {
    "enabled": true
  }
}
