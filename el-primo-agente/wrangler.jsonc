// wrangler.jsonc — Cloudflare Worker "el-primo-agente"
// Agente de WhatsApp (Twilio) + API admin para el dashboard.
//
// IMPORTANTE — los SECRETOS no van aquí. Se cargan con:
//   npx wrangler secret put OPENAI_API_KEY
//   npx wrangler secret put WHATSAPP_ACCOUNT_SID
//   npx wrangler secret put WHATSAPP_AUTH_TOKEN
//   npx wrangler secret put ADMIN_API_TOKEN
//   npx wrangler secret put HUBSPOT_ACCESS_TOKEN
//   npx wrangler secret put COTIZADOR_SECRET
{
  "name": "el-primo-agente",
  "main": "src/index.ts",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,

  "account_id": "0fb22483300c6f8b8d6e8644424b396e",

  // Variables NO secretas (visibles). Los secretos se cargan aparte.
  "vars": {
    "WHATSAPP_SENDER_NUMBER": "+14155238886",
    "AUDENAR_PHONE": "+573223306682",
    "AGENT_ID": "el-primo-agente",
    "HUBSPOT_PIPELINE_ID": "default",
    "HUBSPOT_DEALSTAGE_ID": "1374171315",
    "COTIZADOR_URL": "https://el-primo-cotizador.saulohs16.workers.dev",
    "RENDER_URL": "https://el-primo-render.saulohs16.workers.dev"
  },

  // Base de datos D1 (fuente única de verdad del CRM).
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "elprimo-crm",
      "database_id": "7b67cd56-11ec-4262-839c-9f6bd9e25aef"
    }
  ],

  // KV Namespace para cache caliente de few-shots del curador.
  // Crea el namespace con:
  //   npx wrangler kv namespace create CURATOR_KV
  // Pega el id que devuelva en "id" abajo.
  "kv_namespaces": [
    {
      "binding": "CURATOR_KV",
      "id": "42e006a5db974f508fe6ce0141e48810"
    }
  ],

  // R2 bucket para artefactos (PNG render, SVG plano, DOCX cotización).
  // PENDIENTE: habilitar R2 desde https://dash.cloudflare.com → R2 Object Storage → Enable
  // Luego: npx wrangler r2 bucket create elprimo-artifacts
  // Luego: descomentar el bloque r2_buckets abajo y re-deployar
  //
  // "r2_buckets": [
  //   {
  //     "binding": "ARTIFACTS",
  //     "bucket_name": "elprimo-artifacts"
  //   }
  // ],

  // Cron Trigger — curación autónoma cada 4 horas.
  "triggers": {
    "crons": ["0 */4 * * *"]
  },

  "observability": {
    "enabled": true
  }
}
