    "typecheck": "tsc --noEmit"
  },
  "author": "Horizontes IA",
  "license": "MIT",
  "dependencies": {
    "openai": "^4.67.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.2",
    "wrangler": "^4.101.0"
  }
}
