{
  "name": "el-primo-agente",
  "version": "1.0.0",
  "description": "Cloudflare Worker - Agente de WhatsApp EL PRIMO (prospecta, califica) + API admin del dashboard",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute elprimo-crm --file=src/schema.sql",
